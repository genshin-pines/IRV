# ============================================================
# IRV 智能车载交互与监控系统 — 环境变量模板
# ============================================================
# 复制此文件为 .env 并填入真实值
# 注意: .env 不应提交到 Git

# ── 运行环境 ──────────────────────────────────────────
APP_ENV=dev

# ── 数据库 ────────────────────────────────────────────
DATABASE_URL=sqlite:///./irv.db

# ── 日志 & Agent ──────────────────────────────────────
LOG_LEVEL=INFO
AGENT_POLL_INTERVAL_SEC=3
LOG_COLLECTOR_CAPACITY=2000

# ── LLM 通用配置（支持任何 OpenAI 兼容接口） ──────────
# 只需填 LLM_API_KEY + LLM_BASE_URL + LLM_MODEL 三个变量
# 也兼容旧版 DEEPSEEK_API_KEY / DEEPSEEK_BASE_URL
#
# 常用 Provider 示例:
#   DeepSeek:  LLM_BASE_URL=https://api.deepseek.com/v1          LLM_MODEL=deepseek-v4-flash
#   Kimi:      LLM_BASE_URL=https://api.moonshot.cn/v1           LLM_MODEL=moonshot-v1-8k
#   GPT-4o:    LLM_BASE_URL=https://api.openai.com/v1            LLM_MODEL=gpt-4o
#   Qwen:      LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  LLM_MODEL=qwen-plus
#   GLM:       LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4 LLM_MODEL=glm-4
#   Ollama:    LLM_BASE_URL=http://localhost:11434/v1            LLM_MODEL=llama3
#   vLLM:      LLM_BASE_URL=http://localhost:8000/v1             LLM_MODEL=your-model
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4
LLM_TIMEOUT_SEC=15
LLM_BASE_URL=
LLM_API_KEY=

# ── 融合推理 ──────────────────────────────────────────
EVENT_BUS_WINDOW_SECONDS=2.0
FUSION_DEDUP_MS=500
FUSION_LLM_ENABLED=true

# ── 认证 ──────────────────────────────────────────────
AUTH_SECRET_KEY=irv-local-demo-secret
AUTH_CODE_TTL_SEC=300
AUTH_CODE_COOLDOWN_SEC=60

# ── 短信 / 邮箱验证码（可选）──────────────────────────
SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=

# ── 告警通知（可选）───────────────────────────────────
# 方式一：自定义机器人 Webhook（最简单）
#   在群设置 → 机器人 → 添加自定义机器人 → 复制 Webhook URL
FEISHU_NOTIFY_ENABLED=false
FEISHU_WEBHOOK_URL=

# 方式二：飞书应用机器人（支持 @all、卡片消息）
#   在飞书开放平台创建应用 → 启用机器人能力 → 获取凭证
#   https://open.feishu.cn/app
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=

# ── 交警手势识别 ──────────────────────────────────────
CTPGR_REFERENCE_DIR=D:\download\git\IRV\参考库\ctpgr-publish

# ── 车牌识别阈值 ──────────────────────────────────────
PLATE_CONF_THRESHOLD=0.75
GESTURE_CONF_THRESHOLD=0.75
GESTURE_STABLE_MS=500
GESTURE_COOLDOWN_MS=1000

# ── 事件推送（live_server → 主后端）────────────────────
FUSION_BACKEND_URL=http://localhost:8000
PLATE_PUSH_ENABLED=1
PLATE_PUSH_MIN_CONFIDENCE=0.3
