# ============================================================
# IRV 智能车载交互与监控系统 — 环境变量模板
# ============================================================
# 复制此文件为 backend/.env 并填入真实值
# 注意: .env 不应提交到 Git

# ── 运行环境 ──────────────────────────────────────────
APP_ENV=dev

# ── 数据库 ────────────────────────────────────────────
DATABASE_URL=sqlite:///./irv.db

# ── JWT 认证 ──────────────────────────────────────────
SECRET_KEY=dev-secret-change-in-production

# ── LLM（告警 & 融合推理）────────────────────────────
# DeepSeek API Key — https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
LLM_PROVIDER=deepseek
# 可选: DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── 日志 & Agent ──────────────────────────────────────
LOG_LEVEL=INFO
LOG_COLLECTOR_CAPACITY=500
AGENT_POLL_INTERVAL_SEC=30

# ── 融合推理 ──────────────────────────────────────────
EVENT_BUS_WINDOW_SECONDS=2.0
FUSION_DEDUP_MS=500
FUSION_LLM_ENABLED=true

# ── 告警通知（可选）───────────────────────────────────
# 方式一：自定义机器人 Webhook（最简单）
#   在群设置 → 机器人 → 添加自定义机器人 → 复制 Webhook URL
FEISHU_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=

# 方式二：飞书应用机器人（支持 @all、卡片消息）
#   在飞书开放平台创建应用 → 启用机器人能力 → 获取凭证
#   https://open.feishu.cn/app
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=           # 目标群 ID，从群设置 URL 中获取
FEISHU_NOTIFY_ENABLED=false

# ── 车牌识别阈值 ──────────────────────────────────────
PLATE_CONF_THRESHOLD=0.75
GESTURE_CONF_THRESHOLD=0.75
GESTURE_STABLE_MS=500
GESTURE_COOLDOWN_MS=1000

# ── 事件推送（live_server → 主后端）────────────────────
FUSION_BACKEND_URL=http://localhost:8000
PLATE_PUSH_ENABLED=1
PLATE_PUSH_MIN_CONFIDENCE=0.3
